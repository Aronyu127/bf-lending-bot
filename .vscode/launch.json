{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Funding Bot (once)",
            "type": "debugpy",
            "python": "${workspaceFolder}/.venv/bin/python",
            "request": "launch",
            "program": "${workspaceFolder}/start.py",
            "args": ["0"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Run Funding Bot (once, DRY_RUN)",
            "type": "debugpy",
            "python": "${workspaceFolder}/.venv/bin/python",
            "request": "launch",
            "program": "${workspaceFolder}/start.py",
            "args": ["0"],
            "cwd": "${workspaceFolder}",
            "env": {
                "DRY_RUN": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Start Funding Bot Service",
            "type": "debugpy",
            "python": "${workspaceFolder}/.venv/bin/python",
            "request": "launch",
            "program": "${workspaceFolder}/start.py",
            "args": ["1"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Start Funding Bot Service (DRY_RUN)",
            "type": "debugpy",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/start.py",
            "request": "launch",
            "args": ["1"],
            "cwd": "${workspaceFolder}",
            "env": {
                "DRY_RUN": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
